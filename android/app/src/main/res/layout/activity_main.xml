<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/demo_note" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/connect_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/connectUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/connect_url_hint"
            android:inputType="textUri"
            android:singleLine="true" />

        <EditText
            android:id="@+id/tunAddrInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/tun_addr_hint"
            android:inputType="text"
            android:singleLine="true" />

        <EditText
            android:id="@+id/tunSubnetInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/tun_subnet_hint"
            android:inputType="text"
            android:singleLine="true" />

        <EditText
            android:id="@+id/tunNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/tun_name_hint"
            android:inputType="text"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/connectButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/connect_button" />

            <Button
                android:id="@+id/disconnectButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/disconnect_button" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/native_vpn_label"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/native_vpn_note" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/startNativeVpnButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/start_native_vpn_button" />

            <Button
                android:id="@+id/stopNativeVpnButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/stop_native_vpn_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/nativeVpnStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#E8EFE4"
            android:padding="8dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

        <TextView
            android:id="@+id/nativeVpnErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#B00020"
            android:visibility="gone" />

        <TextView
            android:id="@+id/nativeVpnLogText"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="#EDF6FA"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:padding="10dp"
            android:scrollbars="vertical"
            android:textColor="#17313B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/request_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/httpMethodInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/http_method_hint"
            android:inputType="text"
            android:singleLine="true" />

        <EditText
            android:id="@+id/httpTargetInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/http_target_hint"
            android:inputType="textUri"
            android:singleLine="true" />

        <EditText
            android:id="@+id/httpHeadersInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:hint="@string/http_headers_hint"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <EditText
            android:id="@+id/httpBodyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:hint="@string/http_body_hint"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <Button
            android:id="@+id/requestButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/request_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/ping_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pingTargetInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ping_target_hint"
            android:inputType="text"
            android:singleLine="true" />

        <Button
            android:id="@+id/pingButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ping_button" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/status_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#B00020"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/result_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#111111"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:padding="10dp"
            android:scrollbars="vertical"
            android:textColor="#F5F5F5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/log_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#F4F1EA"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:padding="10dp"
            android:scrollbars="vertical"
            android:textColor="#2C241B" />
    </LinearLayout>
</ScrollView>
